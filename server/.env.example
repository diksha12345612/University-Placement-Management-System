# Server Environment Variables
# Copy this file to .env.production and populate with your actual values
# NEVER commit .env files with actual credentials to Git!
# NEVER hardcode secrets in source code!

# Server Configuration
PORT=5051
NODE_ENV=production

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# JWT Configuration
JWT_SECRET=<generate-with-crypto.randomBytes(32).toString('hex')>
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# API Keys - Store securely in your hosting provider!
GITHUB_TOKEN=ghp_xxxxx...
OPENROUTER_API_KEY=sk-or-v1-xxxxx...
AFFINDA_API_KEY=aff_xxxxx...

# Email Service (Gmail with App Passwords - NOT regular passwords)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=<gmail-app-password-not-account-password>
ADMIN_EMAIL=admin@yourdomain.com

# Demo/Testing (Optional)
DEMO_PASSWORD=<strong-random-password-for-seeded-accounts>

# ⚠️ SECURITY CHECKLIST:
# ✓ Use .env files only for local development
# ✓ Always use environment variable managers for production (Vercel, Railway, Render)
# ✓ Never commit .env files to Git
# ✓ Never hardcode secrets in source code
# ✓ Rotate secrets regularly
# ✓ Use least privilege access

